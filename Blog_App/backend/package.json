  },

  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
